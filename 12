<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DN_Trade | 全平台終端</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;700&family=Noto+Sans+TC:wght@400;700&display=swap');
        body { background: #000; color: #eee; font-family: 'Noto Sans TC', sans-serif; overflow: hidden; margin: 0; }
        .neon-green { color: #39FF14; }
        
        /* 響應式佈局邏輯 */
        .drawer { position: fixed; top: 0; bottom: 60px; width: 85%; background: #050505; z-index: 100; transition: 0.3s; }
        #left-drawer { left: -100%; border-right: 1px solid #222; }
        #right-drawer { right: -100%; border-left: 1px solid #222; }
        #left-drawer.active { left: 0; }
        #right-drawer.active { right: 0; }

        @media (min-width: 1024px) {
            .drawer { position: static; width: auto; height: auto; }
            .mobile-only { display: none; }
        }

        /* 導航標籤 */
        .nav-item { color: #555; font-size: 13px; cursor: pointer; padding: 12px 5px; position: relative; transition: 0.3s; white-space: nowrap; }
        .nav-item.active { color: #39FF14; font-weight: bold; }
        .nav-item.active::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background: #39FF14; box-shadow: 0 0 10px #39FF14; }

        /* Watchlist 項目 */
        .list-item { background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 4px; padding: 12px; margin-bottom: 6px; cursor: grab; font-size: 12px; display: flex; justify-content: space-between; align-items: center; }
        .list-item.active { background: rgba(57,255,20,0.1); border-color: #39FF14; }
        
        /* 底部選單 (手機專用) */
        .mobile-bottom-nav { display: none; position: fixed; bottom: 0; width: 100%; height: 60px; background: #0a0a0a; border-top: 1px solid #222; z-index: 110; }
        @media (max-width: 1024px) { .mobile-bottom-nav { display: flex; justify-content: space-around; align-items: center; } }

        input { background: #0a0a0a; border: 1px solid #333; color: #fff; padding: 10px; border-radius: 4px; width: 100%; font-size: 11px; outline: none; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="h-screen flex flex-col">

    <header class="h-14 flex items-center justify-between px-4 lg:px-6 border-b border-white/10 bg-black z-50">
        <div class="flex items-center gap-4 lg:gap-10">
            <div class="text-xl lg:text-2xl font-bold tracking-tighter">
                <span class="neon-green">DN</span><span class="text-white">_Trade</span>
            </div>
            <nav class="flex gap-4 lg:gap-8 overflow-x-auto no-scrollbar" id="main-nav">
                <div class="nav-item active" data-cat="forex">外匯 Forex</div>
                <div class="nav-item" data-cat="crypto">加密 Crypto</div>
                <div class="nav-item" data-cat="stock">股市 Stock</div>
            </nav>
        </div>
    </header>

    <main class="flex-1 grid grid-cols-12 overflow-hidden p-1 gap-1 relative">
        
        <aside id="left-drawer" class="col-span-12 lg:col-span-2 drawer lg:block">
            <div class="p-5 border-b border-white/5">
                <span class="text-[10px] font-bold text-orange-500 block mb-1">BITOPRO USDT/TWD</span>
                <div id="bito-last" class="text-3xl font-mono neon-green tracking-tighter">--.---</div>
            </div>
            <div class="p-5 border-b border-white/5">
                <span class="text-[10px] font-bold text-blue-500 block mb-1">MAX USDT/TWD</span>
                <div id="max-last" class="text-3xl font-mono text-blue-400 tracking-tighter">--.---</div>
            </div>
            <button onclick="toggleDrawer('left')" class="mobile-only w-full py-4 text-gray-500 text-xs">關閉面板</button>
        </aside>

        <section class="col-span-12 lg:col-span-8 bg-black border border-white/5 overflow-hidden">
            <div id="tv_main" class="h-full w-full"></div>
        </section>

        <aside id="right-drawer" class="col-span-12 lg:col-span-2 drawer lg:flex flex-col">
            <div class="p-3 text-[10px] text-gray-500 font-bold border-b border-white/5 flex justify-between">
                WATCHLIST <span>拖曳排序</span>
            </div>
            <div id="watchlist" class="flex-1 overflow-y-auto p-2 no-scrollbar"></div>
            <div class="p-3 border-t border-white/5">
                <input type="text" id="new-sym" placeholder="新增 (例如 NASDAQ:TSLA)">
                <button onclick="toggleDrawer('right')" class="mobile-only w-full py-3 mt-2 text-gray-500 text-xs">返回圖表</button>
            </div>
        </aside>
    </main>

    <div class="mobile-bottom-nav">
        <button onclick="toggleDrawer('left')" class="text-[10px] text-gray-400">📊 實時匯率</button>
        <button onclick="closeDrawers()" class="text-[10px] neon-green">📉 交易圖表</button>
        <button onclick="toggleDrawer('right')" class="text-[10px] text-gray-400">📜 自選清單</button>
    </div>

    <script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
    <script>
        const STORAGE_KEY = 'DN_Trade_Mobile_Final';
        const defaultLists = {
            forex: ['OANDA:USDTWD', 'FX_IDC:USDCNY', 'FX_IDC:USDMYR'],
            crypto: ['BINANCE:BTCUSDT', 'BINANCE:ETHUSDT', 'BINANCE:SOLUSDT'],
            stock: ['NASDAQ:AAPL', 'NASDAQ:NVDA', 'NASDAQ:IXIC']
        };

        let currentCat = 'forex';
        let storage = JSON.parse(localStorage.getItem(STORAGE_KEY)) || defaultLists;

        // 價格抓取
        async function fetchPrices() {
            try {
                const bito = await fetch('https://api.bitopro.com/v3/tickers/usdt_twd');
                const bitoJ = await bito.json();
                document.getElementById('bito-last').innerText = parseFloat(bitoJ.data.lastPrice).toFixed(3);
                
                const max = await fetch('https://max-api.maicoin.com/api/v2/tickers/usdttwd');
                const maxJ = await max.json();
                document.getElementById('max-last').innerText = parseFloat(maxJ.last).toFixed(3);
            } catch (e) { console.log("Syncing..."); }
        }
        setInterval(fetchPrices, 2000);
        fetchPrices();

        // 介面交互
        function toggleDrawer(side) {
            const left = document.getElementById('left-drawer');
            const right = document.getElementById('right-drawer');
            if (side === 'left') { left.classList.toggle('active'); right.classList.remove('active'); }
            else { right.classList.toggle('active'); left.classList.remove('active'); }
        }

        function closeDrawers() {
            document.getElementById('left-drawer').classList.remove('active');
            document.getElementById('right-drawer').classList.remove('active');
        }

        function loadChart(symbol) {
            new TradingView.widget({
                "autosize": true, "symbol": symbol, "interval": "15", "theme": "dark", "style": "1",
                "locale": "zh_TW", "container_id": "tv_main", "allow_symbol_change": true
            });
            document.querySelectorAll('.list-item').forEach(el => el.classList.toggle('active', el.dataset.sym === symbol));
            if (window.innerWidth < 1024) closeDrawers();
        }

        function renderWatchlist() {
            const listEl = document.getElementById('watchlist');
            listEl.innerHTML = '';
            storage[currentCat].forEach(sym => {
                const div = document.createElement('div');
                div.className = 'list-item';
                div.dataset.sym = sym;
                div.innerHTML = `
                    <div class="flex-1" onclick="loadChart('${sym}')">
                        <div class="font-bold">${sym.split(':')[1] || sym}</div>
                        <div class="text-[9px] text-gray-600">${sym.split(':')[0]}</div>
                    </div>
                    <button onclick="removeSym('${sym}', event)" class="text-gray-600 px-2">&times;</button>`;
                listEl.appendChild(div);
            });
            if (storage[currentCat].length > 0) loadChart(storage[currentCat][0]);
        }

        window.removeSym = function(sym, e) {
            e.stopPropagation();
            storage[currentCat] = storage[currentCat].filter(s => s !== sym);
            save(); renderWatchlist();
        };

        function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(storage)); }

        // 事件監聽
        document.querySelectorAll('.nav-item').forEach(nav => {
            nav.onclick = function() {
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                this.classList.add('active');
                currentCat = this.dataset.cat;
                renderWatchlist();
            };
        });

        document.getElementById('new-sym').onkeypress = function(e) {
            if (e.key === 'Enter' && this.value) {
                storage[currentCat].push(this.value.toUpperCase());
                save(); renderWatchlist(); this.value = '';
            }
        };

        new Sortable(document.getElementById('watchlist'), {
            animation: 150, onEnd: () => {
                storage[currentCat] = Array.from(document.querySelectorAll('.list-item')).map(el => el.dataset.sym);
                save();
            }
        });

        renderWatchlist();
    </script>
</body>
</html>
